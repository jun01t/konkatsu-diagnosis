# --- Vercel 単体デプロイ（推奨）---
# NEXT_PUBLIC_API_URL 未設定 → ブラウザは同一オリジンの /api/*（Route Handlers）
# 本番の OpenAI（未設定ならモック診断）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Go API を別ホストで動かす場合 ---
# NEXT_PUBLIC_API_URL=http://localhost:8080

# OGP・canonical 用（Vercel では未設定でも VERCEL_URL で補完）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
