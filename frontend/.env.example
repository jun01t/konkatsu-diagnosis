# ブラウザから叩く Go API（必ずフロントのオリジンを Go 側 CORS_ORIGINS に追加）
NEXT_PUBLIC_API_URL=http://localhost:8080

# Next のサーバー（generateMetadata / share ページ）から Go へ。未設定時は 127.0.0.1:8080
API_URL=http://127.0.0.1:8080

# OGP・canonical 用の公開URL（本番では https://your-domain.vercel.app など）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
